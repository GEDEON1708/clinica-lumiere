# Supabase: configure para persistir reservas em banco real.
VITE_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# Integração com Google Calendar via Supabase Edge Function.
# Se você estiver usando a Function criada neste repositório, mantenha este provider.
VITE_BOOKING_WEBHOOK_PROVIDER="google-calendar"
VITE_BOOKING_SYNC_FUNCTION_NAME="google-calendar-sync"

# Integração opcional por webhook genérico para outros orquestradores.
VITE_BOOKING_WEBHOOK_URL=""
