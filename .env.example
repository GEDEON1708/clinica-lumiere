# Supabase: configure para persistir reservas em banco real.
VITE_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# Integração opcional com agenda externa.
# Use um webhook público do seu backend, Supabase Edge Function, n8n, Make ou outro orquestrador.
VITE_BOOKING_WEBHOOK_URL="https://YOUR_AUTOMATION_ENDPOINT"
VITE_BOOKING_WEBHOOK_PROVIDER="google-calendar"
